# Shared/public build inputs (safe to embed in client builds)
APP_ENV=development
VITE_API_BASE_URL=http://localhost:5080
FLUTTER_API_BASE_URL=http://10.0.2.2:5080/api/v1

# Backend-only runtime configuration required for the local demo
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://0.0.0.0:5080
ConnectionStrings__Default=Server=localhost;Database=MyFSchool;User Id=CHANGE_ME;Password=CHANGE_ME;TrustServerCertificate=True
Auth__JwtSigningKey=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# Optional Backend overrides. Omit these from the real .env to use appsettings.json defaults.
Auth__Issuer=MyFSchool
Auth__Audience=MyFSchool.Clients
Auth__AccessTokenMinutes=15
Auth__RestrictedTokenMinutes=5
Auth__RefreshTokenDays=7
Auth__TemporaryPasswordHours=24
WebOrigins__AllowedOrigins__0=http://localhost:5173

# Optional one-time Administrator bootstrap.
# Enable only for the first database initialization, then remove all Bootstrap__ keys
# from the real .env after the Administrator can sign in.
Bootstrap__Enabled=false
Bootstrap__AdministratorUserName=CHANGE_ME_ADMIN_USERNAME
Bootstrap__AdministratorEmail=CHANGE_ME_ADMIN_EMAIL
Bootstrap__AdministratorDisplayName=Quản trị viên
Bootstrap__AdministratorPassword=CHANGE_ME_TO_A_UNIQUE_RANDOM_PASSWORD

# Optional Gmail announcement delivery. Keep disabled unless all Gmail values are set.
Smtp__Enabled=false
Smtp__Host=smtp.gmail.com
Smtp__Port=587
Smtp__UserName=CHANGE_ME_TEST_SENDER@gmail.com
Smtp__Password=CHANGE_ME_GOOGLE_APP_PASSWORD
Smtp__FromEmail=CHANGE_ME_TEST_SENDER@gmail.com
Smtp__FromName=MyFSchool
Smtp__Security=startTls
Storage__Provider=Local
Storage__LocalRoot=CHANGE_ME_TO_AN_ABSOLUTE_WRITABLE_PATH_OUTSIDE_THE_REPOSITORY

# QA-only. These are not required for a classroom demo and may be omitted locally.
QA_SQLSERVER_ADMIN_CONNECTION=CHANGE_ME_TO_A_LOCAL_SQL_SERVER_ADMIN_CONNECTION
QA_GMAIL_RECIPIENT=CHANGE_ME_TO_A_DEDICATED_TEST_GMAIL_ADDRESS
